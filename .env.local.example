# Public API endpoints
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=/api

# Public realtime config
NEXT_PUBLIC_REVERB_APP_KEY=your-reverb-app-key
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=http

# Public asset CDN base URL
# Leave empty to use local /public assets during local development.
NEXT_PUBLIC_ASSET_BASE_URL=

# Knowledge / Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:0.6b
KNOWLEDGE_EMBEDDING_MODEL=nomic-embed-text
KNOWLEDGE_SEARCH_METHOD=rag

# Optional AI providers
ZHIPUAI_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_MODEL=MiniMax-M2.5-highspeed

# Optional integrations
GITHUB_PAT=
NEXT_PUBLIC_ERROR_REPORTING_ENDPOINT=
